APP_API_KEY=replace-with-very-strong-secret
APP_CLIENT_SECRET=replace-with-second-very-strong-secret
LLAMA_INTERNAL_API_KEY=replace-with-separate-internal-secret

# Local Windows defaults:
LLAMA_SERVER_PATH=bin/llama-cpp/llama-server.exe
LLAMA_MODEL_PATH=models/qwen2.5-1.5b-instruct-q4_k_m.gguf

# Alternative (for Render/Linux): use HF repo instead of local model path
# LLAMA_HF_REPO=Qwen/Qwen2.5-1.5B-Instruct-GGUF
# LLAMA_HF_FILE=qwen2.5-1.5b-instruct-q4_k_m.gguf

SYSTEM_PROMPT_FILE=prompts/system_prompt.txt
LLAMA_HOST=127.0.0.1
LLAMA_PORT=8081
LLAMA_CTX=1024
LLAMA_BATCH=256
LLAMA_UBATCH=128
LLAMA_FLASH_ATTN=off
LLAMA_THREADS=8
LLAMA_GPU_LAYERS=0
LLAMA_PARALLEL=1
LLAMA_NO_REPACK=1
MAX_INPUT_CHARS=2000
MAX_OUTPUT_TOKENS=72
DEFAULT_TEMPERATURE=0.52
DEFAULT_TOP_P=0.82
DEFAULT_REPEAT_PENALTY=1.30
REQUEST_TIMEOUT_SECONDS=120
FAST_RESPONSE_DEADLINE_SECONDS=2.0
RUNTIME_START_WAIT_SECONDS=1.0
RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=20
RESPONSE_CHECKPOINTS=2
ENABLE_ASYNC_LEARNING_ON_CHAT=1
ASYNC_LEARNING_MAX_CONCURRENCY=1
HISTORY_USER_TURNS=40
MEMORY_SUMMARY_ITEMS=10
ENABLE_WEB_FALLBACK=1
WEB_LOOKUP_FOR_FACTS=1
WEB_LOOKUP_TIMEOUT_SECONDS=12
WEB_CACHE_MAX_ITEMS=800
ENABLE_RELATIONSHIP_LEARNING=1
RELATIONSHIP_BRIDGE_MODE=1
RELATIONSHIP_LEARNING_ON_CHAT=1
RELATIONSHIP_KB_PATH=knowledge_relationship.json
RELATIONSHIP_KB_MAX_ITEMS=5000
RELATIONSHIP_LEARNING_TIMEOUT_SECONDS=14
ENABLE_LIMITS_GUARDRAILS=1
LIMITS_LEARNING_ON_CHAT=1
LIMITS_KB_PATH=knowledge_limits.json
LIMITS_KB_MAX_ITEMS=2500
LIMITS_LEARNING_TIMEOUT_SECONDS=14
ENABLE_BACKGROUND_LEARNING=1
BACKGROUND_LEARNING_SLEEP_MINUTES=180
BACKGROUND_RELATIONSHIP_COUNT=24
BACKGROUND_LIMITS_COUNT=12
ENABLE_LONG_TERM_MEMORY=1
MEMORY_STORE_PATH=memory_store.json
MEMORY_STORE_MAX_USERS=2000
MEMORY_STORE_MAX_ITEMS_PER_USER=160
MEMORY_STORE_READ_ITEMS=10
MEMORY_STORE_WRITE_ITEMS=4
